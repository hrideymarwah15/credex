# Groq — free tier, ~30 req/min on Llama 3.3 70B Versatile.
# Get a key at https://console.groq.com/keys
# If unset, the /api/summarize endpoint returns a templated paragraph instead.
GROQ_API_KEY=

# Supabase — lead capture + shareable audit URLs.
# Create a project at https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend — transactional email (confirmation after lead capture).
# Get a key at https://resend.com/api-keys
# If unset, lead capture still works — email just isn't sent.
RESEND_API_KEY=

# Base URL for email links (deployed URL or http://localhost:3000)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
